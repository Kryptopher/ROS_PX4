# Copy this file to ~/.config/ros_px4/sitl-105.env on the Raspberry Pi.
#
# This profile runs PX4/Gazebo on the PC currently assigned 192.168.0.105.
# The PC must expose its Linux/WSL SSH server on Windows port 2222 and accept
# key-based SSH from the Pi.

SITL_HOST="pc-105-sitl"
SITL_REMOTE_PX4_DIR="~/PX4-Autopilot"

# IP address of the Raspberry Pi as seen by the PC.
SITL_AGENT_IP="192.168.0.155"

SITL_MODE="remote"
SITL_GUI="true"
LOGBOOK_RATE_HZ="100"
EXECUTOR_RATE_HZ="50.0"
