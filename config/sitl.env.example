# Copy this file to ~/.config/ros_px4/sitl.env on the Raspberry Pi.
#
# The laptop must run an SSH server, accept key-based SSH from the Pi, and have
# PX4-Autopilot with its dependencies installed.

SITL_HOST="your-laptop-ssh-host"
SITL_REMOTE_PX4_DIR="~/PX4-Autopilot"

# IP address of the Raspberry Pi as seen by the laptop.
SITL_AGENT_IP="192.168.0.155"

# Remote is the default. Set local to run PX4 and Gazebo on the Pi.
SITL_MODE="remote"

# Headless is recommended. Set true only when the laptop can display Gazebo.
SITL_GUI="false"

# Drone-state sample rate written by the mission logbook.
LOGBOOK_RATE_HZ="100"

# Offboard setpoint publication rate.
EXECUTOR_RATE_HZ="50.0"
